# Build-time (Vite inlines these at build; change = rebuild)
VITE_CONTACT_EMAIL=info@pulsewavetech.io
VITE_SITE_URL=https://pulsewavetech.io

# Cloudflare Tunnel token
# Get it from: Cloudflare Zero Trust -> Networks -> Tunnels -> [tunnel name] -> "Install connector"
# Treat as a secret. Only needed when running with `--profile tunnel` (i.e. production).
CLOUDFLARED_TOKEN=
